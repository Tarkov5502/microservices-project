-Write-Host "=== Recent commits ===" -ForegroundColor Cyan
-& $git log --oneline -5
-
-Write-Host ""
-Write-Host "=== Pushing ===" -ForegroundColor Yellow
-& $git push origin main
-Write-Host "Done!" -ForegroundColor Green
