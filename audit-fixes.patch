@@ -1,120 +0,0 @@
-$git  = "C:\Users\s0e086y\AppData\Local\Programs\Git\cmd\git.exe"
-$proj = "C:\Users\s0e086y\Documents\puppy_workspace\microservices-project"
-Set-Location $proj
