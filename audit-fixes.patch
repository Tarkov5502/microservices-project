diff --git a/terraform/modules/aks/main.tf b/terraform/modules/aks/main.tf
index 00721ad..15b3a10 100644
--- a/terraform/modules/aks/main.tf
+++ b/terraform/modules/aks/main.tf
@@ -130,17 +130,29 @@ resource "azurerm_kubernetes_cluster" "main" {
