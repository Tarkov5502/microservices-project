# ─── Terraform ───────────────────────────────────────────────
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.backup
*.tfplan
*.tfvars.bak
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ─── Python ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
venv/
.venv/
env/
.env
*.log

# ─── Docker ──────────────────────────────────────────────────
.dockerignore

# ─── Kubernetes / Helm ───────────────────────────────────────
*.kubeconfig
kubeconfig
charts/*.tgz

# ─── OS / IDE ────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ─── Secrets (NEVER commit these) ────────────────────────────────────────────────
*.pem
*.key
*.crt
*.pfx
*secret*
*credentials*
service-account*.json
# Fix: cover all .env variants (.env.local, .env.production, .env.staging, etc.)
# The original pattern only matched the exact '.env' filename.
.env
.env.*
*.env
